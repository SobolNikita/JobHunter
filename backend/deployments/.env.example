# Copy to `.env` in this directory and replace every secret before running compose.
#   cp .env.example .env
# Never commit `.env` (see repository root `.gitignore`).

# --- PostgreSQL ---
POSTGRES_USER=jobhunter
POSTGRES_DB=jobhunter
POSTGRES_PASSWORD=replace-with-a-long-random-secret
# Host port (optional; default 5430 if unset in compose)
# POSTGRES_HOST_PORT=5430

# --- Redis ---
REDIS_PASSWORD=replace-with-a-long-random-secret
# REDIS_HOST_PORT=6380

# --- RabbitMQ (do not use username `guest` for connections from other containers) ---
RABBITMQ_DEFAULT_USER=jobhunter
RABBITMQ_DEFAULT_PASS=replace-with-a-long-random-secret
# RABBITMQ_AMQP_HOST_PORT=5672
# RABBITMQ_MANAGEMENT_HOST_PORT=15672

# --- MinIO (MINIO_ROOT_PASSWORD must be at least 8 characters) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-at-least-8-chars
# MINIO_API_HOST_PORT=9000
# MINIO_CONSOLE_HOST_PORT=9001
